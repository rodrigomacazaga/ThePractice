# ============================================================
# The Practice — Variables de entorno
# Copia este archivo a .env y llena los valores reales.
# NUNCA cometas .env al repositorio.
# ============================================================

# --- Base de datos (Neon Postgres recomendado) ---
# DATABASE_URL: conexión pooled (pgbouncer) para runtime serverless.
# DIRECT_URL: conexión directa para migraciones (prisma migrate).
DATABASE_URL="postgresql://user:password@host/thepractice?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host/thepractice?sslmode=require"

# --- Auth ---
# Genera el secret con: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- URLs de la app ---
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Pagos ---
# PAYMENT_PROVIDER: mock | stripe | mercado_pago
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

# --- Email ---
# EMAIL_PROVIDER: mock | resend
EMAIL_PROVIDER=mock
RESEND_API_KEY=
EMAIL_FROM="The Practice <hola@thepractice.mx>"

# --- Storage de archivos ---
# UPLOAD_PROVIDER: mock | cloudinary | supabase
UPLOAD_PROVIDER=mock
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Jobs recurrentes ---
# JOB_PROVIDER: mock | netlify-scheduled | inngest | trigger-dev
JOB_PROVIDER=mock
# Secret para proteger los endpoints de cron (ej. /api/jobs/run)
CRON_SECRET=

# --- Analítica y campañas (landing /la-ceiba) ---
# Los scripts SOLO se cargan si el ID correspondiente está definido.
# Meta Pixel (Facebook/Instagram Ads)
NEXT_PUBLIC_META_PIXEL_ID=
# Google Analytics 4 (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Google Ads (AW-XXXXXXXXX) + label de conversión de lead (form_submit)
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_LEAD_LABEL=

# --- Netlify ---
NETLIFY_NEXT_SKEW_PROTECTION=true

# ============================================================
# Dónde configurar cada variable:
#
# LOCAL (.env):            todas, con valores de desarrollo.
# NETLIFY PRODUCTION:      todas, con valores reales de producción.
#                          NEXTAUTH_URL=https://thepractice.mx
#                          APP_URL / NEXT_PUBLIC_APP_URL=https://thepractice.mx
# NETLIFY DEPLOY PREVIEW:  DATABASE_URL de staging, PAYMENT_PROVIDER=mock,
#                          EMAIL_PROVIDER=mock para no enviar correos reales.
# ============================================================
